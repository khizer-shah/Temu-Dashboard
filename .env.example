# Neon Postgres connection strings (copy to .env and fill with real values).
#
# Get both from the Neon dashboard → your project → Connection Details.
#
# DATABASE_URL: the POOLED connection (host contains "-pooler"). Used at runtime
# by the serverless API functions — pooling is required for serverless.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# DIRECT_URL: the DIRECT connection (no "-pooler"). Used by `prisma db push` and
# migrations, which need a non-pooled connection.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"
